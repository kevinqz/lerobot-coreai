{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/safety-regression-report.schema.json",
  "title": "lerobot-coreai safety regression report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "passed", "baseline", "candidate", "deltas", "checks", "claims"],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.safety_regression_report.v0"},
    "lerobot_coreai_version": {"type": "string"},
    "passed": {"type": "boolean"},
    "baseline": {"type": "object"},
    "candidate": {"type": "object"},
    "deltas": {"type": "object"},
    "checks": {"type": "array", "items": {"type": "object"}},
    "warnings": {"type": "array"},
    "claims": {
      "type": "object",
      "required": ["proves_physical_safety", "proves_real_world_safety"],
      "properties": {
        "proves_no_safety_regression_on_compared_artifacts": {"type": "boolean"},
        "proves_physical_safety": {"type": "boolean", "const": false},
        "proves_real_world_safety": {"type": "boolean", "const": false}
      }
    }
  }
}
