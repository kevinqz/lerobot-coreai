{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/operator-approval.schema.json",
  "title": "lerobot-coreai operator approval",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "lerobot_coreai_version",
    "approval_id",
    "created_at",
    "approved",
    "approved_by",
    "approval_scope",
    "expires_at",
    "bundle",
    "artifacts",
    "checks",
    "operator_attestation",
    "claims"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.operator_approval.v0"},
    "lerobot_coreai_version": {"type": "string"},
    "approval_id": {"type": "string"},
    "created_at": {"type": "string"},
    "approved": {"type": "boolean"},
    "approved_by": {"type": ["string", "null"]},
    "approval_scope": {
      "type": "string",
      "enum": ["sim_only", "sim_to_guarded_real_readiness",
               "guarded_real_dry_run", "guarded_real_single_session"]
    },
    "expires_at": {"type": "string"},
    "bundle": {"type": "object"},
    "artifacts": {"type": "object"},
    "checks": {"type": "array"},
    "operator_overrides": {"type": "object"},
    "operator_attestation": {
      "type": "object",
      "required": ["text", "accepted"],
      "properties": {
        "text": {"type": "string"},
        "accepted": {"type": "boolean"}
      }
    },
    "claims": {
      "type": "object",
      "required": [
        "proves_physical_safety",
        "proves_real_world_safety",
        "authorizes_unrestricted_real_world_actuation"
      ],
      "properties": {
        "proves_operator_reviewed_evidence": {"type": "boolean"},
        "proves_physical_safety": {"type": "boolean", "const": false},
        "proves_real_world_safety": {"type": "boolean", "const": false},
        "authorizes_unrestricted_real_world_actuation": {"type": "boolean", "const": false}
      }
    }
  }
}
