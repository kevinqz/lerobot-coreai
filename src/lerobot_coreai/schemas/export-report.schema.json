{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/export-report.schema.json",
  "title": "lerobot-coreai export report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "lerobot_coreai_version", "ok", "mode", "source", "artifact", "fabric", "verification", "claims", "safety", "errors"],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.export_report.v0"},
    "lerobot_coreai_version": {"type": "string"},
    "ok": {"type": "boolean"},
    "mode": {"type": "string", "const": "export_verify_package"},
    "source": {"type": "object"},
    "artifact": {"type": "object"},
    "fabric": {"type": "object"},
    "verification": {"type": "object"},
    "claims": {
      "type": "object",
      "required": ["proves_task_success", "proves_robot_safety"],
      "properties": {
        "proves_task_success": {"type": "boolean", "const": false},
        "proves_robot_safety": {"type": "boolean", "const": false}
      }
    },
    "safety": {
      "type": "object",
      "required": ["physical_actuation_possible", "motor_commands_available", "robot_connected", "actions_sent"],
      "properties": {
        "physical_actuation_possible": {"type": "boolean", "const": false},
        "motor_commands_available": {"type": "boolean", "const": false},
        "robot_connected": {"type": "boolean", "const": false},
        "actions_sent": {"type": "integer", "const": 0}
      }
    },
    "errors": {"type": "array"}
  }
}
