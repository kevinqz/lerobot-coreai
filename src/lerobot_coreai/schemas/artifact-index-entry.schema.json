{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/artifact-index-entry.schema.json",
  "title": "lerobot-coreai artifact index entry",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "artifact_id", "artifact_type", "artifact_dir",
               "signature_verified", "created_at", "claims"],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.artifact_index_entry.v0"},
    "artifact_id": {"type": "string"},
    "artifact_type": {"type": "string"},
    "artifact_dir": {"type": "string"},
    "policy_path": {"type": ["string", "null"]},
    "dataset_repo_id": {"type": ["string", "null"]},
    "lerobot_coreai_version": {"type": "string"},
    "release_channel": {"type": ["string", "null"]},
    "manifest_sha256": {"type": ["string", "null"]},
    "provenance_sha256": {"type": ["string", "null"]},
    "signature_fingerprint": {"type": ["string", "null"]},
    "signature_verified": {"type": "boolean"},
    "release_check_passed": {"type": ["boolean", "null"]},
    "created_at": {"type": "string"},
    "claims": {
      "type": "object",
      "required": ["proves_physical_safety", "authorizes_robot_actuation"],
      "properties": {
        "proves_physical_safety": {"type": "boolean", "const": false},
        "authorizes_robot_actuation": {"type": "boolean", "const": false},
        "native_upstream_registry": {"type": "boolean", "const": false}
      }
    }
  }
}
