{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/hf-metadata.schema.json",
  "title": "lerobot-coreai HF metadata",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "library_name", "base_library", "runtime",
               "bridge", "safety"],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.hf_metadata.v0"},
    "library_name": {"type": "string", "const": "lerobot-coreai"},
    "base_library": {"type": "string", "const": "lerobot"},
    "lerobot_compatibility": {"type": "string"},
    "lerobot_coreai_version": {"type": "string"},
    "runtime": {"type": "string", "const": "coreai"},
    "policy_path": {"type": ["string", "null"]},
    "robot_type": {"type": ["string", "null"]},
    "bridge": {
      "type": "object",
      "required": ["select_action", "training", "native_registry", "upstream_native"],
      "properties": {
        "select_action": {"type": "boolean"},
        "training": {"type": "boolean", "const": false},
        "native_registry": {"type": "boolean", "const": false},
        "upstream_native": {"type": "boolean", "const": false}
      }
    },
    "safety": {
      "type": "object",
      "required": ["physical_safety_proof", "unrestricted_actuation"],
      "properties": {
        "physical_safety_proof": {"type": "boolean", "const": false},
        "unrestricted_actuation": {"type": "boolean", "const": false}
      }
    }
  }
}
