{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevinqz/lerobot-coreai/main/src/lerobot_coreai/schemas/lerobot-bridge-report.schema.json",
  "title": "lerobot-coreai LeRobot bridge report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "ok", "policy_path", "checks", "claims"],
  "properties": {
    "schema_version": {"type": "string", "const": "lerobot-coreai.lerobot_bridge.v0"},
    "lerobot_coreai_version": {"type": "string"},
    "ok": {"type": "boolean"},
    "policy_path": {"type": "string"},
    "runner_url": {"type": ["string", "null"]},
    "lerobot": {
      "type": "object",
      "properties": {
        "available": {"type": "boolean"},
        "version": {"type": ["string", "null"]},
        "in_range": {"type": ["boolean", "null"]},
        "pretrained_policy_import": {"type": "boolean"}
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed", "severity"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"},
          "severity": {"type": "string", "enum": ["required", "info"]},
          "detail": {"type": "string"}
        }
      }
    },
    "claims": {
      "type": "object",
      "required": [
        "native_upstream_policy_registry",
        "supports_training",
        "proves_physical_safety"
      ],
      "properties": {
        "provides_local_lerobot_bridge": {"type": "boolean"},
        "native_upstream_policy_registry": {"type": "boolean", "const": false},
        "supports_training": {"type": "boolean", "const": false},
        "proves_physical_safety": {"type": "boolean", "const": false}
      }
    }
  }
}
